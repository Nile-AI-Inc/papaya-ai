# Gemini — for the gemini-* and error-handling scripts (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenAI — for langchain-callback.ts and python-* OpenAI examples
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Bedrock — for agent.ts
AWS_PROFILE=
AWS_REGION=us-east-1

# Papaya — required to export traces from the TypeScript examples; optional for
# Python examples when you only want to test the provider call locally.
PAPAYA_API_KEY=
PAPAYA_ENDPOINT=
